NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:5173

# mock uses src/mocks/tickets.mock.js and resets on restart.
# database uses either the sqlflow or nosqlflow adapter path below.
DATA_SOURCE=mock

# Use nosql for document-style stores, or sql for table-style stores.
DB_FLOW=nosql

# Built-in local adapters and ORM/ODM adapters:
# - DB_FLOW=nosql + DB_CLIENT=json-file stores a document collection in DB_FILE_PATH.
# - DB_FLOW=nosql + DB_CLIENT=mongoose connects MongoDB using Mongoose ODM.
# - DB_FLOW=sql + DB_CLIENT=sql-json-file stores table-shaped rows in DB_FILE_PATH.
# - DB_FLOW=sql + DB_CLIENT=sequelize connects SQL using Sequelize ORM.
DB_CLIENT=json-file
DB_FILE_PATH=./data/tickets.json

# SQL database settings used by sqlflow adapters.
# For local Sequelize SQLite ORM mode:
# DB_FLOW=sql
# DB_CLIENT=sequelize
# SQL_DIALECT=sqlite
# SQLITE_STORAGE=./data/tickets.sqlite
SQL_DIALECT=sqlite
SQLITE_STORAGE=./data/tickets.sqlite
SQL_CONNECTION_STRING=
SQL_TICKETS_TABLE=tickets

# NoSQL database settings used by nosqlflow adapters.
# For Mongoose ODM mode:
# DB_FLOW=nosql
# DB_CLIENT=mongoose
# NOSQL_CONNECTION_STRING=mongodb://localhost:27017
NOSQL_CONNECTION_STRING=
NOSQL_DATABASE_NAME=ticketing
NOSQL_TICKETS_COLLECTION=tickets

# To connect a real SQL/NoSQL database, point to an adapter module that exports createTicketAdapter(config).
DB_ADAPTER_PATH=
 